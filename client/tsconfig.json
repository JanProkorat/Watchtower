{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../dist-renderer",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@watchtower/shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
