{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../dist-renderer",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": true
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
