{
  "name": "watchtower",
  "version": "0.0.13",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "npm run build:main && npm run build:orch && concurrently -k -n vite,main,orch,app -c magenta,blue,cyan,green \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:orch\" \"npm:dev:electron\"",
    "dev:main": "tsc -b electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:renderer": "vite --config apps/desktop/vite.config.ts",
    "dev:orch": "tsc -b orchestrator/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on -t 30000 tcp:5173 && cross-env WATCHTOWER_DEV_URL=http://localhost:5173 WATCHTOWER_SUPPORT_DIR=\"$HOME/Library/Application Support/Watchtower-dev\" electron .",
    "build:main": "tsc -b electron/tsconfig.json && node electron/buildPreload.mjs",
    "build:orch": "tsc -b orchestrator/tsconfig.json && node scripts/copy-orch-assets.mjs",
    "build:renderer": "vite build --config apps/desktop/vite.config.ts",
    "build:helper": "node helper/build.mjs",
    "build": "npm run build:main && npm run build:orch && npm run build:renderer && npm run build:helper",
    "start": "npm run build && electron .",
    "electron:rebuild": "electron-rebuild -f",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/shared/tsconfig.json && tsc -p packages/transport/tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit && tsc -p orchestrator/tsconfig.json --noEmit && tsc -p apps/desktop/tsconfig.json --noEmit",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@watchtower/shared": "*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "@mui/icons-material": "^5.16.7",
    "@mui/material": "^5.16.7",
    "@mui/x-date-pickers": "^7.29.4",
    "@react-buddy/ide-toolbox": "^2.5.0",
    "@react-buddy/palette-mui": "^5.0.1",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.16.0",
    "@types/dompurify": "^3.0.5",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.3.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.7",
    "fastify": "^4.28.1",
    "node-pty": "^1.0.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.0",
    "wait-on": "^9.0.10",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "cz.greencode.watchtower",
    "productName": "Watchtower",
    "afterPack": "scripts/adhoc-sign.mjs",
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-orchestrator/**/*",
      "dist-renderer/**/*",
      "dist-helper/**/*",
      "node_modules/**/*",
      "package.json",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/*.placeholder"
    ],
    "extraResources": [
      {
        "from": "build-resources/tray-template.png",
        "to": "tray-template.png"
      },
      {
        "from": "build-resources/tray-template@2x.png",
        "to": "tray-template@2x.png"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*",
      "dist-helper/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": null,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    }
  }
}
